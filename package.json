{
  "name": "spam-checker",
  "version": "1.0.0",
  "description": "Модуль и REST API для проверки текста на спам (лабораторная работа №3, вариант 14)",
  "main": "spamChecker.js",
  "scripts": {
    "test": "jest",
    "test:unit": "jest --config=jest.config.allure.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "bdd": "cucumber-js --format summary --format html:report.html",
    "test:api": "cucumber-js --config cucumber.js",
    "test:ui": "playwright test",
    "test:ui:headed": "playwright test --headed",
    "test:ui:debug": "npx playwright test --debug",
    "test:ui:report": "npx playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "test:all": "npm run test:unit && npm run test:api && npm run test:ui && npm run allure:generate",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "kill": "kill -9 $(lsof -ti :3000) 2>/dev/null || true",
    "static": "npx http-server -c-1 -p 3001",
    "static:dev": "npx http-server -c-1 -p 3001 -o"
  },
  "keywords": [
    "spam",
    "checker",
    "text-analysis"
  ],
  "author": "",
  "license": "ISC",
  "jest": {
    "testPathIgnorePatterns": ["/node_modules/", "/e2e/"]
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@playwright/test": "^1.58.2",
    "allure-commandline": "^2.34.1",
    "allure-cucumberjs": "^3.4.2",
    "allure-jest": "^3.4.2",
    "allure-playwright": "^3.4.2",
    "jest": "^29.7.0",
    "start-server-and-test": "^2.1.2",
    "supertest": "^7.2.2"
  }
}
